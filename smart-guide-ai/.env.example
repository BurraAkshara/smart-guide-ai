# ─────────────────────────────────────────────────────────────
# Smart Guide AI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to version control
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development           # development | production
PORT=5000                      # Express server port

# ── MongoDB ───────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/smart-guide-ai
# Docker Compose (uncomment when using docker-compose):
# MONGODB_URI=mongodb://sgaadmin:sgapassword123@mongo:27017/smart-guide-ai?authSource=admin
# MongoDB Atlas (uncomment for cloud):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/smart-guide-ai?retryWrites=true&w=majority

# MongoDB Docker credentials (only used by docker-compose)
MONGO_USER=sgaadmin
MONGO_PASS=sgapassword123

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES=7d

# ── OpenAI (optional) ─────────────────────────────────────────
# Leave blank to use built-in mock responses (works without an API key)
OPENAI_API_KEY=

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Render Deploy Hook (for CI/CD auto-deploy) ────────────────
# Get this from your Render service → Settings → Deploy Hook
RENDER_DEPLOY_HOOK=

# ─────────────────────────────────────────────────────────────
# Client-side (Vite) — prefix with VITE_
# These go in client/.env
# ─────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
